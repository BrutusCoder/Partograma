{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@partograma/domain(.*)$": "<rootDir>/../../../libs/domain/src$1",
    "^@partograma/validators(.*)$": "<rootDir>/../../../libs/validators/src$1",
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
