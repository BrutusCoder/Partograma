# =============================================================================
# Partograma LCG - Variáveis de Ambiente (Desenvolvimento)
# Copie para .env e ajuste conforme necessário
# =============================================================================

# --- Aplicação ---
NODE_ENV=development
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=partograma
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=partograma-web

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=partograma
DB_PASSWORD=partograma_dev
DB_NAME=partograma_lcg
DB_SCHEMA=lcg
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ---
JWT_SECRET=partograma-dev-secret-change-in-production-abc123
JWT_EXPIRES_IN=8h

# --- Keycloak ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=partograma
KEYCLOAK_CLIENT_ID=partograma-api
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
